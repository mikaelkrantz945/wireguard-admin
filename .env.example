# Database
DATABASE_URL=postgresql://wgadmin:wgadmin@127.0.0.1:5432/wgadmin

# WireGuard
WG_CONFIG_DIR=/etc/wireguard
WG_DEFAULT_DNS=1.1.1.1, 8.8.8.8
WG_DEFAULT_ENDPOINT=vpn.example.com
WG_DEFAULT_SUBNET=10.0.0.0/24
WG_DEFAULT_PORT=51820

# HostBill integration (disabled by default)
HOSTBILL_ENABLED=false
HOSTBILL_WEBHOOK_SECRET=change-me-to-random-secret

# Server
API_PORT=8092

# SMTP (for user invites)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=noreply@example.com
BASE_URL=https://vpn.example.com
