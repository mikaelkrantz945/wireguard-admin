# WireGuard Admin — Environment config
# Managed by Ansible — do not edit manually

DATABASE_URL=postgresql://wgadmin:wgadmin@127.0.0.1:5432/wgadmin

WG_CONFIG_DIR=/etc/wireguard
WG_DEFAULT_DNS=195.47.238.46, 195.47.238.48
WG_DEFAULT_ENDPOINT={{ domain }}
WG_DEFAULT_SUBNET={{ wg_subnet }}
WG_DEFAULT_PORT={{ wg_port }}

HOSTBILL_WEBHOOK_SECRET={{ hostbill_webhook_secret | default('change-me') }}

API_PORT={{ api_port }}

SMTP_HOST={{ smtp_host | default('localhost') }}
SMTP_PORT={{ smtp_port | default('25') }}
SMTP_FROM={{ smtp_from | default('noreply@' + domain) }}
BASE_URL={{ base_url | default('https://' + domain) }}
