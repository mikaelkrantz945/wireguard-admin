# WireGuard Admin — Nginx reverse proxy
# Managed by Ansible — do not edit manually

{% if ssl_mode | default('local') == 'proxy' %}
# Running behind external reverse proxy — HTTP only
server {
    listen {{ listen_port | default('80') }};
    server_name {{ domain }};

    # Trust X-Forwarded-* headers from upstream proxy
    set_real_ip_from {{ trusted_proxy | default('0.0.0.0/0') }};
    real_ip_header X-Forwarded-For;

    location / {
        proxy_pass http://127.0.0.1:{{ api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_read_timeout 300s;
    }
}
{% else %}
# Direct mode — certbot will add SSL
server {
    server_name {{ domain }};

    location / {
        proxy_pass http://127.0.0.1:{{ api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    listen 80;
}
{% endif %}
